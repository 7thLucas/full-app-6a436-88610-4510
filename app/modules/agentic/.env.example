# ──────────────────────────────────────────────────────
# @qb/agentic - environment variables
# Copy these into the project root .env file
# ──────────────────────────────────────────────────────

# Shared secret for the "Authentication" header sent to the agentic service
QB_SCAFFOLDER_KEY=your_api_auth_key

# Keyspace ID — identifies this product to the agentic service
# (sent as the x-id-keyspace header)
_KEYSPACE=your_keyspace_id
